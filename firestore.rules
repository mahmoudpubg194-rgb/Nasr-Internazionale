rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitive Definitions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- PHASE 4: Entity Rules ---

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().keys().hasAll(['uid', 'email'])
        && incoming().uid == request.auth.uid;
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'taxFootprint']);
    }

    // Practices
    match /practices/{practiceId} {
      // Secure List Query (Pillar 8): Enforces that the query MUST filter by userId
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(practiceId)
        && incoming().userId == request.auth.uid
        && incoming().keys().hasAll(['userId', 'type', 'status'])
        && incoming().status in ['received', 'processing', 'review', 'sent', 'completed'];
    }

    // Documents
    match /documents/{docId} {
      // Secure List Query (Pillar 8)
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(docId)
        && incoming().userId == request.auth.uid
        && incoming().keys().hasAll(['userId', 'name', 'url', 'isSigned']);
        
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['isSigned', 'signedAt']);
    }
  }
}
