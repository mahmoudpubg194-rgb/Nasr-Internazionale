{
  "entities": {
    "user_profiles": {
      "title": "User Profiles",
      "description": "Extended user information and tax preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "taxFootprint": {
          "type": "object",
          "properties": {
            "totalPaid": { "type": "number" },
            "totalRecovered": { "type": "number" },
            "year": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "practices": {
      "title": "Practices",
      "description": "Tax and bureaucratic files tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["received", "processing", "review", "sent", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "documents": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["userId", "type", "status"]
    },
    "documents": {
      "title": "Document Vault",
      "description": "Metadata for uploaded and signed documents.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "isSigned": { "type": "boolean" },
        "signedAt": { "type": "string", "format": "date-time" }
      }
    },
    "orders": {
      "title": "Stripe Orders",
      "description": "Record of service purchases.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "stripeSessionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "amount", "status"]
    },
    "bookings": {
      "title": "Bookings",
      "description": "Service reservations and consultations.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "service": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "service", "date", "time", "name", "phone", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "user_profiles",
      "description": "User specific configuration and profile"
    },
    "practices/{practiceId}": {
      "schema": "practices",
      "description": "Tracking for tax practices"
    },
    "documents/{docId}": {
      "schema": "documents",
      "description": "Document metadata"
    },
    "orders/{orderId}": {
      "schema": "orders",
      "description": "Payment records"
    },
    "bookings/{bookingId}": {
      "schema": "bookings",
      "description": "Scheduled consultations"
    }
  }
}
